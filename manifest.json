{
  "manifest_version": 3,
  "name": "Cyborg Disparos",
  "description": "criado por agencia cyborg",
  "version": "1.0.0",
  "icons": {
    "16": "icone.png",
    "48": "icone.png",
    "128": "icone.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "icone.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "ptt-hook.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "world": "ISOLATED"
    }
  ],
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ]
}
